# =============================================================================
# CallIt - Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
POSTGRES_USER=callit
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=callit
POSTGRES_PORT=5432

# Full database URL (used by backend)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://callit:change_this_secure_password@localhost:5432/callit

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_DB=0

# Full Redis URL
REDIS_URL=redis://:change_this_redis_password@localhost:6379/0

# =============================================================================
# Backend Configuration (FastAPI)
# =============================================================================
BACKEND_PORT=8000
SECRET_KEY=generate_a_strong_random_secret_key_here_min_32_chars
DEBUG=true
LOG_LEVEL=info

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Frontend Configuration (React/Vite)
# =============================================================================
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=CallIt

# =============================================================================
# Email Configuration (Optional - for notifications)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@callit.app
SMTP_TLS=true

# =============================================================================
# External Services (Optional)
# =============================================================================
# S3/MinIO for file storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=callit-uploads
S3_REGION=us-east-1

# Stripe for payments (if applicable)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# Monitoring & Logging (Production)
# =============================================================================
SENTRY_DSN=
DATADOG_API_KEY=
